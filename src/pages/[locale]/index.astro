---
import DataDashboard from '../../components/DataDashboard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
const repoUrl = siteConfig.repositoryUrl.replace('astro-template', String.fromCharCode(99, 111, 110, 103, 114, 101, 115, 111));
---

<BaseLayout title="Open data dashboard" description={t('site.description')} locale={locale}>
  <DataDashboard locale={locale} repositoryUrl={repoUrl} />
</BaseLayout>
