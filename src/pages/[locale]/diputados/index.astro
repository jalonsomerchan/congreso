---
import DeputiesIndexPage from '../../../components/DeputiesIndexPage.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { isLocale, useTranslations } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={t('congress.deputies.title')} description={t('congress.deputies.description')} locale={locale}>
  <DeputiesIndexPage locale={locale} />
</BaseLayout>
