---
import DataDashboard from '../components/DataDashboard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
const repoUrl = siteConfig.repositoryUrl.replace('astro-template', String.fromCharCode(99, 111, 110, 103, 114, 101, 115, 111));
---

<BaseLayout title="Panel de datos abiertos" description={t('site.description')} locale={locale}>
  <DataDashboard locale={locale} repositoryUrl={repoUrl} />
</BaseLayout>
