---
interface Props {
  label: string;
  value?: string;
  description?: string;
  tone?: 'default' | 'primary';
}

const { label, value = '—', description = '', tone = 'default' } = Astro.props;
---

<article class:list={['metric-card', `metric-card--${tone}`]}>
  <span>{label}</span>
  <strong data-metric-value>{value}</strong>
  {description && <p>{description}</p>}
</article>

<style>
  .metric-card {
    min-height: 9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    padding: 1.1rem;
  }

  .metric-card--primary {
    background: linear-gradient(135deg, var(--color-primary-soft), var(--color-surface));
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 70%);
  }

  .metric-card span {
    color: var(--color-text-soft);
    display: block;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .metric-card strong {
    display: block;
    font-size: clamp(2.1rem, 8vw, 4rem);
    line-height: 1;
    margin-top: 0.9rem;
  }

  .metric-card p {
    color: var(--color-text-muted);
    margin: 0.7rem 0 0;
  }
</style>
