---
import Container from './Container.astro';
import { dataConfig } from '../config/dataConfig';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { getAlternateLocales, getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath('/', locale);
const alternateLocales = getAlternateLocales(locale);
const navItems = [
  [t('congress.sections.votes'), getLocalizedPath('/votaciones/', locale)],
  [t('congress.deputies.title'), getLocalizedPath('/diputados/', locale)],
  [t('congress.legislature.statsTitle'), getLocalizedPath(`/legislaturas/${dataConfig.currentGroupId}/estadisticas/`, locale)],
];
---

<header class="site-header">
  <Container class="site-header__inner">
    <a class="site-brand" href={homeUrl} aria-label={siteConfig.name}>
      <span class="site-brand__mark" aria-hidden="true">CD</span>
      <span>
        <strong>{siteConfig.name}</strong>
        <small>{t('home.eyebrow')}</small>
      </span>
    </a>
    <nav aria-label={t('nav.main')} class="site-nav">
      <a href={homeUrl}>{t('nav.home')}</a>
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
      <a href={dataConfig.apiBaseUrl}>{t('congress.apiLink')}</a>
    </nav>
    <nav aria-label={t('nav.main')} class="site-locale">
      <button class="theme-toggle" type="button" data-theme-toggle>{t('nav.theme')}</button>
      {alternateLocales.map((alternateLocale) => (
        <a
          href={getLocalizedPath('/', alternateLocale)}
          hreflang={alternateLocale}
        >
          {localeLabels[alternateLocale]}
        </a>
      ))}
    </nav>
  </Container>
</header>

<script>
  const root = document.documentElement;
  const storedTheme = localStorage.getItem('theme');
  if (storedTheme === 'dark') root.dataset.theme = 'dark';

  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
    if (nextTheme === 'dark') {
      root.dataset.theme = 'dark';
      localStorage.setItem('theme', 'dark');
      return;
    }

    delete root.dataset.theme;
    localStorage.setItem('theme', 'light');
  });
</script>
