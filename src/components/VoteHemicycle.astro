---
import { formatNumber, getVoteSeatResults, type VoteType } from '../lib/congressData';
import { getOfficialHemicycleSeatPosition, getOfficialHemicycleSeatPositionsList } from '../lib/officialHemicycle';

interface Totals {
  yes: number;
  no: number;
  abstentions: number;
  absent: number;
  present?: number;
}

interface Props {
  totals: Totals;
  locale: string;
  labels: {
    yes: string;
    no: string;
    abstentions: string;
    absent: string;
    title: string;
    noVote: string;
    telematic: string;
    unmapped: string;
  };
  detail?: any;
  compact?: boolean;
}

type SeatVote = {
  type: 'yes' | 'no' | 'abstention' | 'absent';
  deputy: string;
  group: string;
  vote: string;
};

const { totals, locale, labels, detail = null, compact = false } = Astro.props;
const voteSeats = getVoteSeatResults(detail);
const officialSeatPositions = await getOfficialHemicycleSeatPositionsList();
const officialPositions = await Promise.all(
  voteSeats.map(async (vote) => {
    return getOfficialHemicycleSeatPosition(vote.deputy);
  })
);
const votesByPosition = new Map<string, SeatVote>();
const telematicVotes = voteSeats.filter((vote) => isTelematicSeat(vote.seat)).length;
const unmappedVotes = voteSeats.filter((vote, index) => !isTelematicSeat(vote.seat) && !officialPositions[index]).length;

voteSeats.forEach((vote, index) => {
  const position = officialPositions[index];
  if (!position) return;

  votesByPosition.set(getPositionKey(position), {
    type: getSeatClass(vote.voteType),
    deputy: vote.deputy,
    group: position.group || vote.group,
    vote: vote.vote,
  });
});

function getSeatClass(voteType: VoteType) {
  return voteType === 'abstentions' ? 'abstention' : voteType;
}

function getPositionKey(position: { x: number; y: number }) {
  return `${position.x},${position.y}`;
}

function isTelematicSeat(seat: string | null) {
  return seat === null || seat === '-1';
}
---

<div class:list={['vote-panel', compact && 'vote-panel--compact']}>
  <div class="vote-panel__stats">
    <div class="vote-stat vote-stat--yes"><span>{labels.yes}</span><strong>{formatNumber(totals.yes, locale)}</strong></div>
    <div class="vote-stat vote-stat--no"><span>{labels.no}</span><strong>{formatNumber(totals.no, locale)}</strong></div>
    <div class="vote-stat vote-stat--abstention"><span>{labels.abstentions}</span><strong>{formatNumber(totals.abstentions, locale)}</strong></div>
    <div class="vote-stat vote-stat--absent"><span>{labels.absent}</span><strong>{formatNumber(totals.absent, locale)}</strong></div>
  </div>
  <figure class="hemicycle" aria-label={labels.title}>
    <svg class="hemicycle__map" viewBox="0 0 536 393" role="img">
      <title>{labels.title}</title>
      <g>
        {officialSeatPositions.map((seat, index) => {
          const seatVote = votesByPosition.get(getPositionKey(seat));
          const type = seatVote ? seatVote.type : 'empty';
          const tooltip = [seat.name, seatVote?.group || seat.group, seatVote?.vote || labels.noVote].filter(Boolean).join(' · ');

          return (
          <circle class:list={['seat', `seat--${type}`]} cx={seat.x} cy={seat.y} r={seatVote ? (compact ? 4.2 : 4.6) : (compact ? 3 : 3.3)} data-seat-index={index}>
            <title>{tooltip}</title>
          </circle>
          );
        })}
      </g>
    </svg>
    {(telematicVotes > 0 || unmappedVotes > 0) && (
      <figcaption>
        {telematicVotes > 0 && <span>{labels.telematic}: {formatNumber(telematicVotes, locale)}</span>}
        {telematicVotes > 0 && unmappedVotes > 0 && <span aria-hidden="true"> · </span>}
        {unmappedVotes > 0 && <span>{labels.unmapped}: {formatNumber(unmappedVotes, locale)}</span>}
      </figcaption>
    )}
  </figure>
</div>
